<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= genre.name %> Games</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="specific-info">
    <div class="specific-head">
      <h2><%= genre.name %></h2>
      <button><a href="/genres/<%= genre.id %>/update">Edit</a></button>
      <button><a href="/genres/<%= genre.id %>/delete">Delete</a></button>
    </div>
    <div class="genre-details">
      <div>
        <h3>Description</h3>
        <p><%= genre.description %></p>
      </div>
      <div>
        <button><a href="/genres/<%= genre.id %>/games">View <%= genre.game_count %> <%= genre.name %> Game<%= (genre.game_count === '1') ? '' : 's' %></a></button>
      </div>
    </div>
  </main>
</body>
</html>