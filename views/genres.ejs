<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Genres</title>
</head>
<body>
  <main>
    <a href="/genres/add">Add</a>
    <table>
      <thead>
        <tr>
          <th>Genre</th>
        </tr>
      </thead>
      <tbody>
        <% genres.forEach(genre => { %>
          <%- include('partials/genreEntry', { genre: genre }) %>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>