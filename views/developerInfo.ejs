<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= developer.name %></title>
</head>
<body>
  <main>
    <div>
      <h2><%= developer.name %></h2>
      <a href="/developers/<%= developer.id %>/update">Edit</a>
      <form action="/developers/<%= developer.id %>/delete" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this developer?');">Delete</button>
      </form>
    </div>
    <div>
      <h3>Description</h3>
      <p><%= developer.description %></p>
    </div>
    <div>
      <h3>Founded</h3>
      <p><%= developer.founded %></p>
    </div>
    <div>
      <h3>Country</h3>
      <p><%= developer.country %></p>
    </div>
    <div>
      <a href="/developers/<%= developer.id %>/games"><h3>Games</h3></a>
      <p><%= developer.developed_count %></p>
    </div>
  </main>
</body>
</html>