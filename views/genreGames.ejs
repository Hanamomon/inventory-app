<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Developer</th>
      </tr>
    </thead>
    <tbody>
      <% games.forEach(game => { %>
        <%- include('partials/gameEntry', { game: game }) %>
      <% }) %>
    </tbody>
  </table>
</body>
</html>