<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= genre.name %> Games</title>
</head>
<body>
  <main>
    <div>
      <h2><%= genre.name %></h2>
      <a href="/genres/<%= genre.id %>/update">Edit</a>
      <form action="/genres/<%= genre.id %>/delete" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this genre?');">Delete</button>
      </form>
    </div>
    <div>
      <h3>Description</h3>
      <p><%= genre.description %></p>
    </div>
    <div>
      <a href="/genres/<%= genre.id %>/games"><h3>Games</h3></a>
      <p><%= genre.game_count %></p>
    </div>
  </main>
</body>
</html>